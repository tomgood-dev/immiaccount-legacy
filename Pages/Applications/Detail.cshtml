@page "/Applications/{appId}"
@model ImmiAccount.Pages.Applications.DetailModel
@{
    Layout = "_AppLayout";
}

<div class="app-info-section">
    <h3>Application Details</h3>
    <div class="app-info-grid">
        <div class="app-info-row">
            <span class="app-info-label">Reference Number</span>
            <span class="app-info-value">@Model.Application!.ReferenceNumber</span>
        </div>
        <div class="app-info-row">
            <span class="app-info-label">Visa Subclass</span>
            <span class="app-info-value">@Model.Application.Subclass!.Name</span>
        </div>
        <div class="app-info-row">
            <span class="app-info-label">Stream</span>
            <span class="app-info-value">@Model.Application.Subclass.Stream</span>
        </div>
        <div class="app-info-row">
            <span class="app-info-label">Pathway Type</span>
            <span class="app-info-value">@Model.Application.Subclass.PathwayType</span>
        </div>
        <div class="app-info-row">
            <span class="app-info-label">Current Status</span>
            <span class="app-info-value"><strong>@Model.Application.CurrentStatus</strong></span>
        </div>
        <div class="app-info-row">
            <span class="app-info-label">Date Lodged</span>
            <span class="app-info-value">@DateHelper.Format(Model.Application.DateLodged)</span>
        </div>
        <div class="app-info-row">
            <span class="app-info-label">Last Updated</span>
            <span class="app-info-value">@DateHelper.Format(Model.Application.LastUpdated)</span>
        </div>
        @if (Model.Application.SponsorName != null)
        {
            <div class="app-info-row">
                <span class="app-info-label">Sponsor</span>
                <span class="app-info-value">@Model.Application.SponsorName</span>
            </div>
        }
    </div>
</div>

<div class="app-info-section">
    <h3>Applicant</h3>
    <div class="app-info-grid">
        <div class="app-info-row">
            <span class="app-info-label">Name</span>
            <span class="app-info-value">@Model.Application.Applicant!.GivenNames @Model.Application.Applicant.FamilyName</span>
        </div>
        <div class="app-info-row">
            <span class="app-info-label">Date of Birth</span>
            <span class="app-info-value">@DateHelper.Format(Model.Application.Applicant.DateOfBirth)</span>
        </div>
    </div>
</div>

<div class="processing-time-note">
    <strong>Estimated processing time:</strong>
    Global processing times are published monthly.
    <a href="https://immi.homeaffairs.gov.au/visas/getting-a-visa/visa-processing-times" target="_blank">View current processing times</a>.
    <br><br>
    Processing times are indicative only and may vary depending on individual circumstances.
    You will be notified by email when a decision is made on your application.
    Contact your migration agent if you have questions about the progress of your application.
</div>
