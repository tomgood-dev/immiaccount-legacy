@{
    Layout = "_Layout";
    var appId = ViewData["AppId"]?.ToString() ?? "";
    var activeTab = ViewData["ActiveTab"]?.ToString() ?? "home";
    var appRef = ViewData["AppReference"]?.ToString() ?? "";
    var appSubclass = ViewData["AppSubclassName"]?.ToString() ?? "";
}

<div class="app-top-bar">
    <span class="app-top-bar-title">
        Application for @appSubclass &nbsp;&nbsp; Reference Number: @appRef
    </span>
    <div class="app-top-bar-icons">
        <a href="#" title="Print">&#128424;</a>
        <a href="#" title="Help" style="border: 1px solid white; border-radius: 50%; width: 18px; height: 18px; display: inline-flex; align-items: center; justify-content: center; font-size: 12px; font-weight: bold;">?</a>
    </div>
</div>

<div class="app-detail-wrapper">
    <div class="app-sidebar">
        <div class="sidebar-section-title">Menu</div>
        <a href="/Applications/@appId" class="sidebar-menu-item @(activeTab == "home" ? "active" : "")">Application home</a>
        <a href="/Applications/@appId/Messages" class="sidebar-menu-item @(activeTab == "messages" ? "active" : "")">Messages</a>
        <a href="#" class="sidebar-menu-item">Update details</a>
        <a href="#" class="sidebar-menu-item">Bridging visa</a>

        <div class="sidebar-section-title" style="margin-top: 8px;">Actions</div>
        <a href="/Applications/@appId/Documents" class="sidebar-menu-item @(activeTab == "documents" ? "active" : "")">Attach documents</a>
        <a href="#" class="sidebar-menu-item">Biometrics collection</a>
        <a href="#" class="sidebar-menu-item">Health assessment</a>
    </div>

    <div class="app-main-content">
        @RenderBody()
    </div>
</div>
