@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(ViewData["Title"] ?? "ImmiAccount") - Department of Home Affairs</title>
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>

<header class="site-header">
    <div class="header-inner">
        <div class="header-left">
            <div class="gov-branding">
                <div class="gov-crest">
                    <svg width="44" height="52" viewBox="0 0 44 52" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Australian Government Crest">
                        <path d="M2 2 H42 V30 Q42 50 22 50 Q2 50 2 30 Z" fill="none" stroke="white" stroke-width="2"/>
                        <line x1="22" y1="2" x2="22" y2="50" stroke="white" stroke-width="1"/>
                        <line x1="2" y1="22" x2="42" y2="22" stroke="white" stroke-width="1"/>
                        <circle cx="10" cy="12" r="1.5" fill="white"/>
                        <circle cx="14" cy="8" r="1.5" fill="white"/>
                        <circle cx="18" cy="12" r="1.5" fill="white"/>
                        <circle cx="14" cy="16" r="1.5" fill="white"/>
                        <circle cx="14" cy="12" r="1" fill="white"/>
                        <circle cx="28" cy="10" r="1.5" fill="white"/>
                        <circle cx="32" cy="14" r="1.5" fill="white"/>
                        <circle cx="36" cy="10" r="1.5" fill="white"/>
                        <circle cx="12" cy="35" r="1.5" fill="white"/>
                        <circle cx="22" cy="32" r="2" fill="white"/>
                        <circle cx="32" cy="35" r="1.5" fill="white"/>
                        <circle cx="17" cy="40" r="1" fill="white"/>
                        <circle cx="27" cy="40" r="1" fill="white"/>
                    </svg>
                </div>
                <div class="gov-text">
                    <span class="gov-name">Australian Government</span>
                    <span class="dept-name">Department of Home Affairs</span>
                </div>
            </div>
        </div>
        <div class="header-right">
            @{
                var displayName = Context.Session.GetString("DisplayName");
            }
            @if (displayName != null)
            {
                <div class="header-user-row">
                    <span>@displayName</span>
                    &nbsp;&nbsp;
                    <a href="/ManageAccount">Manage Account</a>
                    &nbsp;|&nbsp;
                    <a href="/Logout">Logout</a>
                </div>
            }
            else
            {
                <div class="header-user-row">&nbsp;</div>
            }
            <div>
                <span class="gov-title">@(ViewData["PortalTitle"] ?? "ImmiAccount")</span>
            </div>
        </div>
    </div>
</header>

@{
    var path = Context.Request.Path.Value ?? "";
    var isPaymentsPage = ViewData["PaymentsPage"] != null;
}

@if (isPaymentsPage)
{
    <nav class="site-nav">
        <div class="nav-inner">
            <a href="/Applications" class="nav-tab active">My applications</a>
        </div>
    </nav>
}
else
{
    <nav class="site-nav">
        <div class="nav-inner">
            <a href="/Applications" class="nav-tab @(path.StartsWith("/Applications") ? "active" : "")">My applications</a>
            <a href="/Payments" class="nav-tab @(path.StartsWith("/Payments") ? "active" : "")">My payments &#9660;</a>
            <a href="#" class="nav-tab">Manage groups</a>
            <a href="#" class="nav-tab">Related links &#9660;</a>
            <a href="#" class="nav-tab">Help and support &#9660;</a>
        </div>
    </nav>
}

<main class="main-content">
    @RenderBody()
</main>

<footer class="site-footer">
    <a href="#">Accessibility</a>
    <a href="#">Online Security</a>
    <a href="#">Privacy</a>
    <a href="#">Copyright &amp; Disclaimer</a>
</footer>

</body>
</html>
